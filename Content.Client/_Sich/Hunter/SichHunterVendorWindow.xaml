<controls:SichHunterVendorWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._Sich.Hunter"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    MinSize="500 700">
    <PanelContainer Name="Background">
        <BoxContainer Orientation="Vertical" Margin="5">
            <BoxContainer Orientation="Horizontal">
                <Label Text="Пошук" Align="Left" />
                <LineEdit Name="Search" Access="Public" HorizontalExpand="True" Margin="10 0 0 0" />
                <Control HorizontalExpand="True" SizeFlagsStretchRatio="0.25" />
                <Label Name="PointsLabel" Access="Public" HorizontalExpand="True" Align="Right" />
            </BoxContainer>
            <cc:HSeparator Color="#700303" />
            <BoxContainer Name="ReagentsContainer" Access="Public" Orientation="Horizontal">
                <Label Text="Речовини" Margin="0 0 5 0" />
                <ProgressBar Name="ReagentsBar" Access="Public" HorizontalExpand="True">
                    <Label Name="ReagentsLabel" Access="Public" HorizontalAlignment="Right" />
                </ProgressBar>
            </BoxContainer>
            <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
                <BoxContainer Orientation="Vertical" Name="Sections" Access="Public" />
            </ScrollContainer>
        </BoxContainer>
    </PanelContainer>
</controls:SichHunterVendorWindow>
