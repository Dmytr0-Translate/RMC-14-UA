<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               Title="Корпоративний термінал"
               Resizable="False"
               MinWidth="500"
               MinHeight="400">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True">
        <PanelContainer VerticalExpand="True" HorizontalExpand="True" MouseFilter="Pass">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="Black"/>
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" HorizontalExpand="True">
                <Label Name="AuthLabel" HorizontalAlignment="Right" Visible="False" Margin="0 4 10 0"/>
                <Control MinHeight="30"/>
                <ScrollContainer Name="Scroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False" Margin="10">
                    <RichTextLabel Name="MessageHistory" VerticalAlignment="Top" HorizontalExpand="True"/>
                </ScrollContainer>
            </BoxContainer>
        </PanelContainer>
        <BoxContainer Name="InputContainer" Orientation="Horizontal" Visible="False" Margin="4">
            <LineEdit Name="InputBar" HorizontalExpand="True" PlaceHolder="Type message..."/>
            <Button Name="SendButton" Text="Send"/>
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
