<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Термінал: Адмін-повідомлення"
    MinWidth="400"
    MinHeight="100">
    <BoxContainer Orientation="Vertical" Margin="8">
        <LineEdit Name="MessageInput" PlaceHolder="Введіть повідомлення для терміналу..." HorizontalExpand="True"/>
        <Button Name="SubmitButton" Text="Відправити" HorizontalAlignment="Center" Margin="0 8 0 0"/>
    </BoxContainer>
</DefaultWindow>
